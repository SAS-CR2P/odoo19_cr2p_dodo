<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================================================================
         Vue formulaire FEC - Interface entièrement en français
         Remplace la vue anglaise de l10n_fr_account pour le mode
         Facturation (sans account_accountant).
    ================================================================ -->
    <record id="view_l10n_fr_fec_invoicing_wizard_form" model="ir.ui.view">
        <field name="name">l10n_fr.fec.export.wizard.invoicing.form</field>
        <field name="model">l10n_fr.fec.export.wizard</field>
        <!-- Priorité plus haute que la vue standard (defaut 16) -->
        <field name="priority">20</field>
        <field name="arch" type="xml">
            <form string="Génération du Fichier FEC">

                <!-- Alerte mode officiel : rappel du verrouillage d'exercice -->
                <div class="alert alert-warning" role="alert" invisible="test_file">
                    <strong>Export officiel :</strong>
                    Le téléchargement du FEC positionnera la date de verrouillage
                    de l'exercice à la date de fin sélectionnée.
                    Cochez <em>Mode test</em> pour générer le fichier sans verrouillage.
                </div>

                <!-- Alerte mode test -->
                <div class="alert alert-info" role="alert" invisible="not test_file">
                    <strong>Mode test activé :</strong>
                    Le fichier FEC sera généré sans modifier la date de verrouillage
                    de l'exercice. Vous pouvez inclure les écritures non validées.
                </div>

                <notebook>

                    <!-- ======== ONGLET OPTIONS ======== -->
                    <page string="Options" name="options">
                        <group string="Période">
                            <field name="date_from"
                                   string="Date de début"
                                   required="1"/>
                            <field name="date_to"
                                   string="Date de fin"
                                   required="1"/>
                        </group>
                        <group string="Paramètres">
                            <field name="test_file"
                                   string="Mode test (sans verrouillage d'exercice)"/>
                            <field name="export_type"
                                   string="Type d'export"
                                   invisible="not test_file"
                                   widget="radio"/>
                            <field name="excluded_journal_ids"
                                   string="Journaux à exclure"
                                   widget="many2many_tags"
                                   options="{'no_create': True}"
                                   placeholder="Laisser vide pour inclure tous les journaux"/>
                        </group>
                    </page>

                    <!-- ======== ONGLET INFOS TECHNIQUES ======== -->
                    <page string="Format du fichier" name="technical_info">
                        <group>
                            <div colspan="2" class="text-muted">
                                <p>
                                    Fichier texte encodé en <strong>UTF-8</strong>,
                                    séparateur <strong>pipe "|"</strong>,
                                    fin de ligne <strong>CR+LF</strong>.
                                    Conforme à la spécification DGFiP (art. L.47 A LPF).
                                </p>
                                <p>
                                    Nom du fichier généré :
                                    <code>[SIREN]FEC[AAAAMMJJ].txt</code>
                                </p>
                            </div>
                        </group>
                        <group>
                            <table class="table table-sm table-bordered" style="width:90%" colspan="2">
                                <thead class="table-light">
                                    <tr>
                                        <th style="width:5%">Col.</th>
                                        <th style="width:25%">Nom technique</th>
                                        <th>Description</th>
                                        <th>Source Odoo</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td>0</td>
                                        <td><code>JournalCode</code></td>
                                        <td>Code du journal</td>
                                        <td>account.journal.code</td>
                                    </tr>
                                    <tr>
                                        <td>1</td>
                                        <td><code>JournalLib</code></td>
                                        <td>Libellé du journal</td>
                                        <td>account.journal.name</td>
                                    </tr>
                                    <tr>
                                        <td>2</td>
                                        <td><code>EcritureNum</code></td>
                                        <td>Numéro de l'écriture</td>
                                        <td>account.move.name</td>
                                    </tr>
                                    <tr>
                                        <td>3</td>
                                        <td><code>EcritureDate</code></td>
                                        <td>Date de l'écriture (AAAAMMJJ)</td>
                                        <td>account.move.date</td>
                                    </tr>
                                    <tr>
                                        <td>4</td>
                                        <td><code>CompteNum</code></td>
                                        <td>Numéro de compte (PCG)</td>
                                        <td>account.account.code</td>
                                    </tr>
                                    <tr>
                                        <td>5</td>
                                        <td><code>CompteLib</code></td>
                                        <td>Libellé du compte</td>
                                        <td>account.account.name</td>
                                    </tr>
                                    <tr>
                                        <td>6</td>
                                        <td><code>CompAuxNum</code></td>
                                        <td>N° compte auxiliaire (tiers — clients/fournisseurs)</td>
                                        <td>res.partner.ref ou id</td>
                                    </tr>
                                    <tr>
                                        <td>7</td>
                                        <td><code>CompAuxLib</code></td>
                                        <td>Libellé du compte auxiliaire</td>
                                        <td>res.partner.name</td>
                                    </tr>
                                    <tr>
                                        <td>8</td>
                                        <td><code>PieceRef</code></td>
                                        <td>Référence de la pièce justificative</td>
                                        <td>account.move.ref</td>
                                    </tr>
                                    <tr>
                                        <td>9</td>
                                        <td><code>PieceDate</code></td>
                                        <td>Date de la pièce (AAAAMMJJ)</td>
                                        <td>account.move.invoice_date ou date</td>
                                    </tr>
                                    <tr>
                                        <td>10</td>
                                        <td><code>EcritureLib</code></td>
                                        <td>Libellé de l'écriture</td>
                                        <td>account.move.line.name</td>
                                    </tr>
                                    <tr>
                                        <td>11</td>
                                        <td><code>Debit</code></td>
                                        <td>Montant débit (virgule décimale)</td>
                                        <td>account.move.line.debit</td>
                                    </tr>
                                    <tr>
                                        <td>12</td>
                                        <td><code>Credit</code></td>
                                        <td>Montant crédit (virgule décimale)</td>
                                        <td>account.move.line.credit</td>
                                    </tr>
                                    <tr>
                                        <td>13</td>
                                        <td><code>EcritureLet</code></td>
                                        <td>Lettre de lettrage</td>
                                        <td>account.full.reconcile.id</td>
                                    </tr>
                                    <tr>
                                        <td>14</td>
                                        <td><code>DateLet</code></td>
                                        <td>Date de lettrage (AAAAMMJJ)</td>
                                        <td>account.full.reconcile.create_date</td>
                                    </tr>
                                    <tr>
                                        <td>15</td>
                                        <td><code>ValidDate</code></td>
                                        <td>Date de validation (AAAAMMJJ)</td>
                                        <td>account.move.date</td>
                                    </tr>
                                    <tr>
                                        <td>16</td>
                                        <td><code>Montantdevise</code></td>
                                        <td>Montant en devise étrangère</td>
                                        <td>account.move.line.amount_currency</td>
                                    </tr>
                                    <tr>
                                        <td>17</td>
                                        <td><code>Idevise</code></td>
                                        <td>Code devise ISO 4217</td>
                                        <td>res.currency.name</td>
                                    </tr>
                                </tbody>
                            </table>
                        </group>
                    </page>

                </notebook>

                <footer>
                    <button string="Générer le FEC"
                            name="create_fec_report_action"
                            type="object"
                            class="btn-primary"
                            data-hotkey="q"/>
                    <button string="Annuler"
                            class="btn-secondary"
                            special="cancel"
                            data-hotkey="x"/>
                </footer>

            </form>
        </field>
    </record>

    <!-- ================================================================
         Action : ouvre le wizard en popup
    ================================================================ -->
    <record id="action_l10n_fr_fec_invoicing_wizard" model="ir.actions.act_window">
        <field name="name">Export FEC</field>
        <field name="res_model">l10n_fr.fec.export.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_l10n_fr_fec_invoicing_wizard_form"/>
        <field name="target">new</field>
        <field name="help" type="html">
            <p>
                Générez votre Fichier des Écritures Comptables (FEC)
                conformément à l'article L.47 A du Livre des Procédures Fiscales.
            </p>
        </field>
    </record>

</odoo>
