<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
        Stratégie de menu :

        On ajoute le FEC export sous le menu racine de la Facturation / Comptabilité
        (account.menu_finance), qui existe dans le module account de base.

        Un sous-menu "Rapports légaux" est créé pour regrouper
        les exports obligatoires français.

        Structure résultante :
            Facturation (ou Comptabilité)
            └── Rapports légaux
                └── Export FEC
    -->

    <!-- Sous-menu "Rapports légaux" -->
    <menuitem
        id="menu_l10n_fr_legal_reports"
        name="Rapports légaux"
        parent="account.menu_finance"
        sequence="99"
        groups="account.group_account_manager"/>

    <!-- Item "Export FEC" -->
    <menuitem
        id="menu_l10n_fr_fec_invoicing"
        name="Export FEC (Fichier des Écritures Comptables)"
        parent="menu_l10n_fr_legal_reports"
        action="action_l10n_fr_fec_invoicing_wizard"
        sequence="10"
        groups="account.group_account_manager"/>

</odoo>
