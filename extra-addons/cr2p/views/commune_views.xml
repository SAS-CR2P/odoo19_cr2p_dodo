<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_commune_form" model="ir.ui.view">
        <field name="name">commune form</field>
        <field name="model">commune</field>
        <field name="arch" type="xml">
            <form string="Commune">
                <sheet>
                    <group>
                        <field name="code_postal"/>
                        <field name="nom"/>
                        <field name="code_insee"/>
                        <field name="latitude"/>
                        <field name="longitude"/>
                        <field name="code_departement"/>
                        <field name="nom_departement"/>
                        <field name="code_region"/>
                        <field name="nom_region"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_commune_tree" model="ir.ui.view">
        <field name="name">commune tree</field>
        <field name="model">commune</field>
        <field name="arch" type="xml">
            <list string="Communes">
                <field name="code_postal"/>
                <field name="nom"/>
                <field name="code_insee"/>
                <field name="latitude"/>
                <field name="longitude"/>
                <field name="code_departement"/>
                <field name="nom_departement"/>
                <field name="code_region"/>
                <field name="nom_region"/>
            </list>
        </field>
    </record>

    <record id="action_commune" model="ir.actions.act_window">
        <field name="name">Communes</field>
        <field name="res_model">commune</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_commune" name="Communes"
              action="action_commune"
              parent="contacts.res_partner_menu_config"
              groups="base.group_system"/>
</odoo>