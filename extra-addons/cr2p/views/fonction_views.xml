<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_fonction_form" model="ir.ui.view">
        <field name="name">fonction form</field>
        <field name="model">fonction</field>
        <field name="arch" type="xml">
            <form string="Fonction">
                <sheet>
                    <group>
                        <field name="name"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_fonction_tree" model="ir.ui.view">
        <field name="name">fonction tree</field>
        <field name="model">fonction</field>
        <field name="arch" type="xml">
            <list string="Fonctions">
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="action_fonction" model="ir.actions.act_window">
        <field name="name">Fonctions</field>
        <field name="res_model">fonction</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_fonction" name="Fonctions"
              action="action_fonction"
              parent="contacts.res_partner_menu_config"
              groups="base.group_system"/>
</odoo>