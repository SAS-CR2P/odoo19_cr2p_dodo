<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_source_contacts_form" model="ir.ui.view">
        <field name="name">source_contacts form</field>
        <field name="model">source_contacts</field>
        <field name="arch" type="xml">
            <form string="Source de contacts">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="enfant" />
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_source_contacts_tree" model="ir.ui.view">
        <field name="name">source_contacts tree</field>
        <field name="model">source_contacts</field>
        <field name="arch" type="xml">
            <list string="Sources de contacts">
                <field name="name"/>
                <field name="enfant"/>
            </list>
        </field>
    </record>

    <record id="action_source_contacts" model="ir.actions.act_window">
        <field name="name">Sources de contacts</field>
        <field name="res_model">source_contacts</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_source_contacts_enfant_form" model="ir.ui.view">
        <field name="name">source_contacts_enfant form</field>
        <field name="model">source_contacts.enfant</field>
        <field name="arch" type="xml">
            <form string="Source de contacts - Enfant">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="parent" domain="[('enfant', '=', True)]" />
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_source_contacts_enfant_tree" model="ir.ui.view">
        <field name="name">source_contacts_enfant tree</field>
        <field name="model">source_contacts.enfant</field>
        <field name="arch" type="xml">
            <list string="Sources de contacts - Enfants">
                <field name="name"/>
                <field name="parent"/>
            </list>
        </field>
    </record>

    <record id="action_source_contacts_enfant" model="ir.actions.act_window">
        <field name="name">Sources de contacts - Enfants</field>
        <field name="res_model">source_contacts.enfant</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menutitle_source_contacts" name="Sources de contacts"
              parent="contacts.res_partner_menu_config"
              groups="base.group_system"/>

    <menuitem id="menu_source_contacts" name="Sources de contacts"
              action="action_source_contacts"
              parent="menutitle_source_contacts"
              groups="base.group_system"/>
    
    <menuitem id="menu_source_contacts_enfant" name="Sources de contacts - Enfants"
              action="action_source_contacts_enfant"
              parent="menutitle_source_contacts"
              groups="base.group_system"/>
</odoo>